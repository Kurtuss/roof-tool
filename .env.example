# ── Auth ────────────────────────────────────────────────────────
# Password to access the admin area
APP_PASSWORD=changeme

# ── Database ─────────────────────────────────────────────────────
# Absolute path for the SQLite database file
# On Railway/Render, mount a volume at /data and use /data/roof.db
DATABASE_PATH=./data/roof-tool.db

# ── Company Info (used in PDF reports) ──────────────────────────
COMPANY_NAME=Your Roofing Co
COMPANY_TAGLINE=Professional Roofing Services
COMPANY_PHONE=(555) 000-0000
COMPANY_EMAIL=info@yourroofingco.com
COMPANY_ADDRESS=123 Main St, City, State 00000

# ── Pricing (per sq ft unless noted) ────────────────────────────
RATE_REROOF=4.50
RATE_SPRAY=2.00
RATE_TUNEUP=1.25
RATE_GUTTER=3.00
TAX_RATE=0.08
